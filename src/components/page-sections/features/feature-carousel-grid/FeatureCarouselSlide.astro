---
import FeatureCarouselCard from "@features/feature-carousel-grid/FeatureCarouselCard.astro";
import BentoBoxGrid from "@wrappers/bento-box-grid/BentoBoxGrid.astro";
import CarouselSlide from "@wrappers/carousel/CarouselSlide.astro";

const {
  cards = [],
  colorScheme = "inherit",
  backgroundColor,
  class: className,
  _component,
  editable = false,
  ...htmlAttributes
} = Astro.props;
---

<CarouselSlide {...htmlAttributes}>
  <BentoBoxGrid
    class:list={["feature-carousel-slide-grid", className]}
    gap="xs"
    data-children-prop="cards"
  >
    {
      cards.map((card: any) =>
        card.decorative ? (
          <FeatureCarouselCard
            columnSpan={card.columnSpan}
            rowSpan={card.rowSpan}
            backgroundColor={card.style}
            border={false}
            data-editable="array-item"
            data-id="building-blocks/wrappers/bento-box-grid/bento-box-grid-item"
          />
        ) : (
          <FeatureCarouselCard
            {...card}
            backgroundColor="base"
            border={true}
            data-editable="array-item"
            data-id="building-blocks/wrappers/bento-box-grid/bento-box-grid-item"
          />
        )
      )
    }
  </BentoBoxGrid>
</CarouselSlide>

<style is:global>
  @layer page-sections {
    .feature-carousel-slide-grid {
      width: 100%;
      padding: var(--spacing-sm);
    }
  }
</style>
