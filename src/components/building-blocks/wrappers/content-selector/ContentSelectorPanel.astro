---
import RenderBlock from "@components/utils/renderBlock.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Text from "@core-elements/text/Text.astro";

const {
  title,
  subtext,
  contentSections,
  editable = false,
  checked = false,
  groupName = "content-selector-tabs",
  navigationPosition = "start",
  _component,
  "data-children-prop": childrenDataProp,
  ...htmlAttributes
} = Astro.props;

const uniqueId = crypto.randomUUID();
const tabId = `tab-${uniqueId}`;
const panelId = `panel-${uniqueId}`;
const tabLabelId = `tablabel-${uniqueId}`;

const effectiveChildrenProp = childrenDataProp ?? (editable ? "contentSections" : null);
const arrayDataAttributes = effectiveChildrenProp
  ? { "data-editable": "array", "data-prop": effectiveChildrenProp }
  : {};
---

<div
  class="content-selector-item"
  {...htmlAttributes}
>
  <input
    type="radio"
    name={groupName}
    id={tabId}
    class="content-selector-input"
    checked={checked}
    autocomplete="off"
  />
  <label
    class="content-selector-tab"
    id={tabLabelId}
    for={tabId}
  >
    <Heading
      text={title}
      level="h3"
      size="h3"
      alignX="start"
      class="content-selector-tab-heading"
    />
    {
      subtext && (
        <Text
          text={subtext}
          alignX="start"
          class="content-selector-tab-subtext"
        />
      )
    }
  </label>
  <div
    class="content-selector-panel"
    id={panelId}
    aria-labelledby={tabLabelId}
  >
    <div
      class="content-selector-panel-content"
      {...arrayDataAttributes}
    >
      <slot>
        {
          contentSections && (
            <RenderBlock
              contentSections={contentSections}
              editable={!!effectiveChildrenProp}
            />
          )
        }
      </slot>
    </div>
  </div>
</div>

<style is:global>
  @layer components {
    .content-selector-item {
      display: contents;
    }

    .content-selector-input {
      display: none;
    }

    .content-selector-tab {
      background: transparent;
      border: none;
      cursor: pointer;
      display: block;
      padding: var(--spacing-md);
      position: relative;
      text-align: start;
      transition: background-color var(--animation-extra-fast) ease-in-out;
      width: 100%;

      * {
        color: var(--color-text-muted);
      }

      &::before {
        background: var(--color-text-disable);
        content: "";
        position: absolute;
        transition:
          transform var(--animation-fast),
          background var(--animation-fast);
      }

      &:hover {
        background: var(--color-bg-accent);
      }

      > .content-selector-tab-heading {
        margin: 0;
      }

      > .content-selector-tab-subtext,
      > .content-selector-tab-subtext * {
        margin: 0;
        font-weight: var(--font-weight-normal);
      }
    }

    .content-selector-input:checked + .content-selector-tab,
    .content-selector-input:checked + .content-selector-tab * {
      color: var(--color-text-strong);
    }

    .content-selector-input:checked + .content-selector-tab::before {
      background: var(--color-bg-primary);
    }

    .content-selector-input:checked + .content-selector-tab + .content-selector-panel {
      display: block;
    }

    .content-selector-panel {
      animation: fade-in var(--animation-slow) ease-in-out forwards;
      container-type: inline-size;
      display: none;
    }

    .content-selector-panel-content > *:first-child {
      margin-top: 0 !important;
    }
  }
</style>
