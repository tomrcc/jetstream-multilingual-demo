---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Bar from "@components/navigation/bar/Bar.astro";
import Mobile from "@components/navigation/mobile/Mobile.astro";
import Image from "@core-elements/image/Image.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";

const {
  logoSource,
  logoAlt = "logo",
  navData = [],
  buttonSections = [],
  class: className,
  _component,
  ...htmlAttributes
} = Astro.props;

const mobileNavData = [
  ...navData,
  ...buttonSections.map((button: any) => ({
    name: button.text || "Button",
    path: button.href || "#",
    children: [],
  })),
];
---

<CustomSection
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical="none"
  colorScheme="light"
  backgroundColor=""
  class:list={["main-nav", className]}
  {...htmlAttributes}
>
  <a href="/">
    <Image
      source={logoSource}
      class="main-nav-logo"
      alt={logoAlt}
      editable={false}
    />
  </a>
  <div class="nav-end">
    <Bar
      navData={navData}
      class="desktop-main-nav"
    />

    <ButtonGroup
      direction="row"
      align="center"
      class="desktop-button-group"
      style="gap: var(--spacing-xl);"
      buttonSections={buttonSections}
      editable={false}
    />
  </div>
  <Mobile
    logoSource={logoSource}
    logoAlt={logoAlt}
    navData={mobileNavData}
    class="mobile-main-nav"
  />
</CustomSection>

<style is:global>
  @layer page-sections {
    .main-nav {
      z-index: var(--layer-2);
      padding: var(--spacing-md) var(--spacing-sm);
      position: sticky;
      top: 0;
      overflow: visible;
      pointer-events: none;

      .desktop-main-nav.bar,
      .desktop-button-group.button-group {
        @container (max-width: 768px) {
          display: none;
        }
      }

      .main-nav-logo {
        margin-top: 0 !important;
      }

      .nav-hamburger.mobile-button {
        @container (min-width: 769px) {
          display: none;
        }
      }

      > .outer-content > .content {
        align-items: center;
        container-type: inline-size;
        display: flex;
        gap: var(--spacing-md);
        background-color: var(--color-bg);
        border: 2px solid var(--color-border-subtle);
        box-shadow: 10px 10px 29px 10px var(--color-shadow);
        padding: var(--spacing-md) var(--spacing-md) var(--spacing-md) var(--spacing-2xl);
        border-top-left-radius: var(--radius-4xl);
        border-bottom-left-radius: var(--radius-4xl);
        border-top-right-radius: var(--radius-md);
        border-bottom-right-radius: var(--radius-md);
        pointer-events: all;

        > a > .image img {
          height: 1.25em;
          max-width: 150px;
        }

        > a {
          flex-shrink: 0;
        }

        .button-group {
          margin-top: 0;

          > .button-group__items {
            gap: var(--spacing-xl);
            width: auto;
          }

          .button > .button-inner {
            border-radius: var(--radius-sm);
          }
        }
      }

      > .outer-content > .content > .nav-end {
        align-items: center;
        display: flex;
        justify-content: flex-end;
        width: 100%;
        flex-grow: 1;
        > .button-group {
          container-type: normal;
          flex: 0 0 auto;
          width: auto;
        }
      }
    }
  }
</style>
