{
  "name": "jetstream-astro-template",
  "type": "module",
  "version": "1.0.0",
  "description": "Jetstream is a polished, high-performance marketing website template for Astro.",
  "keywords": [
    "astro",
    "cloudcannon",
    "ssg",
    "astro-theme",
    "astrojs",
    "astro-template",
    "astro-themes",
    "cloudcannon-themes",
    "ssg-astro"
  ],
  "author": "CloudCannon",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "DISABLE_COMPONENT_DOCS=true astro build",
    "build:with-docs": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "npm run lint && npm run format",
    "check:fix": "npm run lint:fix && npm run format:fix",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:yml",
    "lint:js": "eslint .",
    "lint:yml": "eslint \"**/*.{yml,yaml}\"",
    "lint:fix": "npm run lint:js:fix && npm run lint:css:fix && npm run lint:yml:fix",
    "lint:js:fix": "eslint . --fix",
    "lint:yml:fix": "eslint \"**/*.{yml,yaml}\" --fix",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "stylelint \"**/*.css\" --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.12",
    "@astrojs/sitemap": "^3.5.1",
    "@choctawnationofoklahoma/lite-vimeo": "^1.3.1",
    "@cloudcannon/editable-regions": "^0.0.10",
    "@justinribeiro/lite-youtube": "^1.8.2",
    "@types/js-yaml": "^4.0.9",
    "astro": "^5.17.0",
    "astro-auto-import": "^0.4.5",
    "astro-icon": "^1.1.5",
    "astro-seo": "^0.8.4",
    "embla-carousel": "^8.6.0",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "glob": "^11.0.3",
    "js-beautify": "^1.15.4",
    "js-yaml": "^4.1.0",
    "markdown-it": "^14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.34.3",
    "shiki": "^3.9.2",
    "unpic": "^4.1.3",
    "zod": "^4.0.17",
    "@astrojs/node": "^9.5.4",
    "lightningcss": "^1.31.1",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "eslint": "^9.33.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsonc": "^2.20.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-yml": "^1.18.0",
    "jsonc-eslint-parser": "^2.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^16.23.1",
    "stylelint-config-standard": "^38.0.0",
    "stylelint-order": "^7.0.0",
    "yaml-eslint-parser": "^1.3.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "optionalDependencies": {
    "@img/sharp-linux-x64": "^0.33.5",
    "@img/sharp-linuxmusl-x64": "^0.33.5",
    "@rollup/rollup-linux-x64-gnu": "^4.24.0",
    "@rollup/rollup-win32-x64-msvc": "^4.24.0"
  },
  "overrides": {
    "lodash": "^4.17.22"
  }
}
